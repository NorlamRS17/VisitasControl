# ===========================================
# V&C Control - Variables de Entorno (Ejemplo)
# ===========================================
# Copiar a .env y ajustar valores

# PostgreSQL
POSTGRES_USER=vccontrol
POSTGRES_PASSWORD=vccontrol123
POSTGRES_DB=vccontrol_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@vccontrol.com
PGADMIN_PASSWORD=admin123

# Backend
DATABASE_URL=postgresql://vccontrol:vccontrol123@localhost:5432/vccontrol_db
SECRET_KEY=cambiar_esta_clave_en_produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend
VITE_API_URL=http://localhost:8000/api
